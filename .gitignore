# Keep results/ (results.json, pareto.png, champion.json) committed as run evidence.

# LLM weight dataset (downloaded models + packed binaries; regenerable) —
# but KEEP result logs, figures, and notes: they are the paper's run evidence.
weights/data/*
!weights/data/*.log
!weights/data/*.txt
!weights/data/*.md
!weights/data/*.png
!weights/data/*.json

